# Backend base URL
# - Use your backend origin (scheme + host + optional port)
# - No trailing slash required (it will be normalized)
#
# Examples:
# VITE_API_BASE_URL=http://localhost:8080
# VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# Dev-only test login (optional)
VITE_TEST_EMAIL=
VITE_TEST_PASSWORD=
