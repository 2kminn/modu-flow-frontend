{
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/proxy?path=:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "functions": {
    "api/proxy.js": { "maxDuration": 10 },
    "api/oauth2/authorization/[provider].js": { "maxDuration": 10 }
  }
}
